{
	"name": "DevAllInOne",
	"displayName": "DevAllInOne",
	"description": "Make all develop environments in one workspace, make everything easier",
	"version": "0.0.8",
	"publisher": "CSSDC-ADAS",
	"private": true,
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/kokomaya/DevAlli-InOne"
	},
	"engines": {
		"vscode": "^1.73.0"
	},
	"categories": [
		"Other"
	],
	"icon": "media/dep.png",
	"activationEvents": [
		"onStartupFinished",
		"onLanguage:json",
		"onLanguage:jsonc"
	],
	"main": "./out/extension.js",
	"contributes": {
		"viewsContainers": {
			"activitybar": [
				{
					"id": "package-explorer",
					"title": "DevAllInOne",
					"icon": "media/dep.svg"
				}
			]
		},
		"views": {
			"package-explorer": [
				{
					"id": "DevAllInOne",
					"name": "Rad6xx DevPlay",
					"icon": "media/dep.svg",
					"contextualTitle": "Rad6xx DevPlay"
				},
				{
					"id": "DevAllInOneBookmarks",
					"name": "Bookmarks",
					"icon": "media/dep.svg",
					"contextualTitle": "Bookmarks"
				}
			],
			"explorer": [
				{
					"id": "jsonOutline",
					"name": "Json Outline",
					"when": "jsonOutlineEnabled"
				}
			]
		},
		"commands": [
			{
				"command": "DevAllInOne.selectJsonFile",
				"title": "DevAllInOne:Select json file"
			},
			{
				"command": "DevAllInOne.showRegexpLookupTable",
				"title": "DevAllInOne:Show ReEx Lookup Table"
			},
			{
				"command": "DevAllInOne.showAsciiLookupTable",
				"title": "DevAllInOne:Show ASCII Lookup Table"
			},
			{
				"command": "DevAllInOne.showHttpClient",
				"title": "DevAllInOne:HTTP Client"
			},
			{
				"command": "DevAllInOne.showEnvVariables",
				"title": "DevAllInOne:Environment Variables"
			},
			{
				"command": "DevAllInOne.showExecutionCenter",
				"title": "DevAllInOne:Execution Center"
			},
			{
				"command": "DevAllInOne.showDashboard",
				"title": "DevAllInOne:Quick Access Dashboard",
				"icon": {
					"light": "resources/light/dependency.svg",
					"dark": "resources/dark/dependency.svg"
				}
			},
			{
				"command": "DevAllInOne.toggleFavorite",
				"title": "Toggle Favorite",
				"icon": {
					"light": "resources/light/edit.svg",
					"dark": "resources/dark/edit.svg"
				}
			},
			{
				"command": "DevAllInOne.removeFavorite",
				"title": "Remove Favorite"
			},
			{
				"command": "DevAllInOne.runFavoriteByIndex",
				"title": "DevAllInOne:Run Favorite By Index"
			},
			{
				"command": "DevAllInOne.runWithLogs",
				"title": "Run (logs)",
				"icon": {
					"light": "resources/light/refresh.svg",
					"dark": "resources/dark/refresh.svg"
				}
			},
			{
				"command": "DevAllInOne.runSequence",
				"title": "Run Sequence",
				"icon": {
					"light": "resources/light/refresh.svg",
					"dark": "resources/dark/refresh.svg"
				}
			},
			{
				"command": "DevAllInOne.addBookmark",
				"title": "DevAllInOne:Add Bookmark"
			},
			{
				"command": "DevAllInOne.removeBookmark",
				"title": "Remove Bookmark",
				"icon": {
					"light": "resources/light/refresh.svg",
					"dark": "resources/dark/refresh.svg"
				}
			},
			{
				"command": "DevAllInOne.showMenu",
				"title": "显示菜单"
			},
			{
				"command": "DevAllInOne.refreshEntry",
				"title": "Refresh",
				"icon": {
					"light": "resources/light/refresh.svg",
					"dark": "resources/dark/refresh.svg"
				},
				"detail": {}
			},
			{
				"command": "DevAllInOne.addEntry",
				"title": "Add"
			},
			{
				"command": "DevAllInOne.editEntry",
				"title": "Edit",
				"icon": {
					"light": "resources/light/edit.svg",
					"dark": "resources/dark/edit.svg"
				}
			},
			{
				"command": "DevAllInOne.deleteEntry",
				"title": "Delete"
			},
			{
				"command": "DevAllInOne.renameEntry",
				"title": "Rename"
			},
			{
				"command": "jsonOutline.refresh",
				"title": "Refresh",
				"icon": {
					"light": "resources/light/refresh.svg",
					"dark": "resources/dark/refresh.svg"
				}
			},
			{
				"command": "jsonOutline.refreshNode",
				"title": "Refresh",
				"icon": {
					"light": "resources/light/refresh.svg",
					"dark": "resources/dark/refresh.svg"
				}
			},
			{
				"command": "jsonOutline.renameNode",
				"title": "Rename"
			},
			{
				"command": "fileExplorer.refreshFile",
				"title": "Refresh",
				"icon": {
					"light": "resources/light/refresh.svg",
					"dark": "resources/dark/refresh.svg"
				}
			},
			{
				"command": "testView.changeTitle",
				"title": "Test View: Change Title"
			}
		],
		"menus": {
			"view/title": [
				{
					"command": "DevAllInOne.showDashboard",
					"when": "view == DevAllInOne",
					"group": "navigation"
				},
				{
					"command": "DevAllInOne.refreshEntry",
					"when": "view == DevAllInOne",
					"group": "navigation"
				},
				{
					"command": "DevAllInOne.showExecutionCenter",
					"when": "view == DevAllInOne",
					"group": "navigation"
				},
				{
					"command": "jsonOutline.renameNode",
					"when": "view == jsonOutline"
				},
				{
					"command": "DevAllInOne.addEntry",
					"when": "view == DevAllInOne"
				},
				{
					"command": "jsonOutline.refresh",
					"when": "view == jsonOutline",
					"group": "navigation"
				}
			],
			"view/item/context": [
				{
					"command": "DevAllInOne.runWithLogs",
					"when": "view == DevAllInOne && (viewItem == action || viewItem == action-fav)",
					"group": "inline"
				},
				{
					"command": "DevAllInOne.runSequence",
					"when": "view == DevAllInOne && viewItem == group",
					"group": "inline"
				},
				{
					"command": "DevAllInOne.runSequence",
					"when": "view == DevAllInOne && viewItem == group",
					"group": "1_modification"
				},
				{
					"command": "DevAllInOne.toggleFavorite",
					"when": "view == DevAllInOne && (viewItem == action || viewItem == action-fav)",
					"group": "9_fav"
				},
				{
					"command": "DevAllInOne.removeFavorite",
					"when": "view == DevAllInOne && viewItem == action-fav",
					"group": "9_fav"
				},
				{
					"command": "DevAllInOne.editEntry",
					"when": "view == DevAllInOne && (viewItem == action || viewItem == action-fav)",
					"group": "inline"
				},
				{
					"command": "DevAllInOne.addEntry",
					"when": "view == DevAllInOne && viewItem == group",
					"group": "1_modification"
				},
				{
					"command": "DevAllInOne.editEntry",
					"when": "view == DevAllInOne && (viewItem == action || viewItem == action-fav)",
					"group": "1_modification"
				},
				{
					"command": "DevAllInOne.renameEntry",
					"when": "view == DevAllInOne && (viewItem == action || viewItem == action-fav || viewItem == group)",
					"group": "1_modification"
				},
				{
					"command": "DevAllInOne.deleteEntry",
					"when": "view == DevAllInOne && (viewItem == action || viewItem == action-fav || viewItem == group)",
					"group": "1_modification"
				},
				{
					"command": "jsonOutline.renameNode",
					"when": "view == jsonOutline"
				},
				{
					"command": "jsonOutline.refreshNode",
					"when": "view == jsonOutline",
					"group": "inline"
				},
				{
					"command": "fileExplorer.refreshFile",
					"when": "view == fileExplorer && viewItem == file",
					"group": "inline"
				},
				{
					"command": "DevAllInOne.removeBookmark",
					"when": "view == DevAllInOneBookmarks && viewItem == bookmark",
					"group": "inline"
				}
			],
			"editor/context": [
				{
					"command": "DevAllInOne.addBookmark",
					"group": "navigation",
					"when": "editorTextFocus"
				}
			]
		},
		"keybindings": [
			{
				"command": "DevAllInOne.runFavoriteByIndex",
				"key": "alt+1",
				"args": 1
			},
			{
				"command": "DevAllInOne.runFavoriteByIndex",
				"key": "alt+2",
				"args": 2
			},
			{
				"command": "DevAllInOne.runFavoriteByIndex",
				"key": "alt+3",
				"args": 3
			},
			{
				"command": "DevAllInOne.runFavoriteByIndex",
				"key": "alt+4",
				"args": 4
			},
			{
				"command": "DevAllInOne.runFavoriteByIndex",
				"key": "alt+5",
				"args": 5
			},
			{
				"command": "DevAllInOne.runFavoriteByIndex",
				"key": "alt+6",
				"args": 6
			},
			{
				"command": "DevAllInOne.runFavoriteByIndex",
				"key": "alt+7",
				"args": 7
			},
			{
				"command": "DevAllInOne.runFavoriteByIndex",
				"key": "alt+8",
				"args": 8
			},
			{
				"command": "DevAllInOne.runFavoriteByIndex",
				"key": "alt+9",
				"args": 9
			}
		],
		"configuration": [
			{
				"type": "object",
				"properties": {
					"DevAllInOne.jsonFilePath": {
						"type": "string",
						"default": "",
						"description": "Select json file(s) for the setting, muptiple selections are seperated by semicolon."
					},
					"DevAllInOne.jsonMerge": {
						"type": "boolean",
						"description": "Merge setting json file to workspace json, in spite of the existence file /conf/config*.json.",
						"default": true
					}
				}
			}
		]
	},
	"scripts": {
		"vscode:prepublish": "npm run compile",
		"compile": "tsc -p ./",
		"watch": "tsc -watch -p ./",
		"lint": "eslint \"src/**/*.ts\""
	},
	"devDependencies": {
		"@types/ftp": "^0.3.33",
		"@types/mkdirp": "^0.5.2",
		"@types/node": "^20.19.43",
		"@types/rimraf": "^2.0.2",
		"@types/vscode": "^1.73.0",
		"@typescript-eslint/eslint-plugin": "^7.14.0",
		"@typescript-eslint/parser": "^7.14.0",
		"eslint": "^8.26.0",
		"typescript": "^5.6.2"
	},
	"dependencies": {
		"deepmerge": "^4.3.1",
		"ftp": "^0.3.10",
		"json-merge": "^1.2.0",
		"jsonc-parser": "^0.4.2",
		"minimist": "^1.2.6",
		"mkdirp": "^0.5.1",
		"rimraf": "^2.6.2"
	}
}
